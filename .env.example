# =============================================================================
# A CASA DOS 20 — Variáveis de Ambiente
# =============================================================================
# INSTRUÇÕES:
# 1. Copia este ficheiro para ".env" no teu computador (nunca commites o .env)
# 2. Preenche os valores reais ao lado de cada chave
# 3. No Replit: Secrets = sensíveis | Configurations = valores públicos
# =============================================================================


# =============================================================================
# SECRETS (Tools → Secrets no Replit)
# =============================================================================

# --- BASE DE DADOS -----------------------------------------------------------
# Ligação à base de dados Neon PostgreSQL
# Obtém em: console.neon.tech → o teu projeto → Connection string
NEON_DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# --- AUTENTICAÇÃO GOOGLE -----------------------------------------------------
# Obtém em: console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URIs: https://SEU_DOMINIO/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Chave API do Google (para funcionalidades adicionais)
GOOGLE_API_KEY=

# Segredo para assinar as sessões de utilizador (string longa aleatória)
# Gera um com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# --- NOTIFICAÇÕES PUSH (VAPID) -----------------------------------------------
# IMPORTANTE: a chave pública e privada têm de ser sempre o mesmo par.
# Se gerares um par novo, os utilizadores perdem as subscrições até voltarem a aceitar.
# Para gerar um par novo: npx web-push generate-vapid-keys
VAPID_PRIVATE_KEY=

# --- STRIPE (PAGAMENTOS) -----------------------------------------------------
# Obtém em: dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...

# --- EMAIL (BREVO) -----------------------------------------------------------
# Obtém em: app.brevo.com → Account → SMTP & API → API Keys
BREVO_API_KEY=

# --- SLACK (NOTIFICAÇÕES INTERNAS) -------------------------------------------
# Chave de API do Slack para notificações internas de teste
SLACK_TEST_API_KEY=


# =============================================================================
# CONFIGURATIONS (Tools → Secrets → "New configuration" no Replit)
# Estes valores não são sensíveis — podem ser partilhados sem problema
# =============================================================================

# Chave pública das notificações push (não é secreta — vai para o browser dos utilizadores)
# Par atual — NÃO ALTERAR sem alterar também VAPID_PRIVATE_KEY
VAPID_PUBLIC_KEY=BFWf1qCLJrnOiDrZZLmAeQHnAedp_ycyifaCZogdcyk_-aqx_J-c11XzQQpa8NcAb_TerKj-Zy3-QHFfXH8nBmk

# Email de contacto para o serviço de push notifications
VAPID_SUBJECT=mailto:quinzinhooliveiraa@gmail.com


# =============================================================================
# VARIÁVEIS GERIDAS AUTOMATICAMENTE PELO REPLIT (não precisas de definir)
# =============================================================================
# REPLIT_DOMAINS=
# PORT=5000
# NODE_ENV=development
